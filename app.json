{
  "expo": {
    "name": "Dose & Mood",
    "slug": "dose-and-mood",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "scheme": "doseandmood",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF6EF"
    },
    "ios": {
      "bundleIdentifier": "com.doseandmood.logger",
      "buildNumber": "1",
      "supportsTablet": false,
      "icon": "./assets/app-icon.png",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleDisplayName": "Dose & Mood"
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "package": "com.doseandmood.logger",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF6EF"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "appMode": "local-first logger",
      "privacyPromise": "MVP entries are stored locally and exported only when the user chooses."
    }
  }
}
